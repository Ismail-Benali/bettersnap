{
  "manifest_version": 3,
  "name": "BetterSnap - Make Snapchat Web Better",
  "description": "Screenshot & View Unread Chats, Send as Mobile, and more! Works on Chrome, Firefox, Edge, and all modern browsers.",
  "version": "2.0.0",
  "icons": {
    "16": "icons/logo16.png",
    "32": "icons/logo32.png",
    "48": "icons/logo48.png",
    "96": "icons/logo96.png",
    "128": "icons/logo128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.snapchat.com/*",
        "https://*.snapchat.com/*"
      ],
      "css": [
        "build/script.css"
      ],
      "js": [
        "build/inject.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "build/script.js"
      ],
      "matches": [
        "https://web.snapchat.com/*",
        "https://*.snapchat.com/*"
      ]
    }
  ],
  "permissions": [],
  "host_permissions": [
    "https://web.snapchat.com/*",
    "https://*.snapchat.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{bettersnap-universal@bettersnap.dev}",
      "strict_min_version": "109.0"
    }
  }
}